# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging
build/
dist/
build_demo/
dist_demo/
dist_demo*/
*.egg-info/

# Test and coverage
.coverage
.coverage.*
htmlcov/

# Logs
*.log

# Environment files
.env
.env.*

# OS / editor files
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
.codex/
.streamlit/

# Data outputs (keep folder structure)
data/raw/*
!data/raw/.gitkeep

data/snapshots/*
!data/snapshots/.gitkeep

data/outputs/*
!data/outputs/.gitkeep

data/logs/*
!data/logs/.gitkeep

# Global index runtime file
data/index/*
!data/index/.gitkeep

# Job runs runtime files
data/job_runs/*
!data/job_runs/.gitkeep

# Parsed outputs runtime files
data/parsed/*
!data/parsed/.gitkeep

# History runtime files
data/history/*
!data/history/.gitkeep

# Discovery outputs runtime files
data/discovered/*
!data/discovered/.gitkeep

# Harvest outputs runtime files
data/harvest/*
!data/harvest/.gitkeep


# Export outputs runtime files
data/exports/*
!data/exports/.gitkeep

# Published outputs runtime files
data/published/*
!data/published/.gitkeep


# Pipeline run runtime files
data/pipeline_runs/*
!data/pipeline_runs/.gitkeep

